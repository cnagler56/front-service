# Local dev environment for the Next.js front-service.
#
# Usage:
#   1. Copy this file to `.env.local` (gitignored by Next.js convention).
#   2. Fill in any values that differ from the defaults below.
#   3. `npm run dev` automatically picks up `.env.local`.
#
# In production set the same vars in your host's environment
# (Vercel, Railway, Render, Cloudflare Pages, etc).

# Where AgriServer is running. Defaults to localhost:8081 in api.ts if
# not set, but production must point at the real backend URL (with HTTPS).
NEXT_PUBLIC_API_URL=http://localhost:8081
